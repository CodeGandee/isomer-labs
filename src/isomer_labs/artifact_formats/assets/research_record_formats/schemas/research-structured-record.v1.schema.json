{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isomer:research/record-format/schema/research-structured-record/v1",
  "title": "Family-neutral structured research record",
  "type": "object",
  "required": ["title", "summary", "artifact_family", "semantic_id", "artifact_type", "sections"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "artifact_family": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "semantic_id": {"type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+)*:[A-Z0-9]+(?:-[A-Z0-9]+)*$"},
    "artifact_type": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "sections": {"type": "object", "minProperties": 1},
    "actor": {"type": "object"},
    "relationships": {"type": "array", "items": {"type": "object"}},
    "files": {"type": "array", "items": {"type": "object"}},
    "procedure": {"type": "string"},
    "terminal_status": {"type": "string"},
    "research_idea_effects": {"$ref": "#/$defs/researchIdeaEffects"}
  },
  "allOf": [
    {
      "if": {
        "required": ["artifact_family", "artifact_type", "research_idea_effects"],
        "properties": {
          "artifact_family": {"const": "kaoju"},
          "artifact_type": {"const": "direction-set"}
        }
      },
      "then": {
        "properties": {
          "sections": {
            "required": ["proposals", "selections", "confirmation"],
            "properties": {
              "proposals": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "idea_id", "title", "summary", "research_question", "boundary", "source_classes", "coverage_date", "expected_depth", "deliverables", "empirical_feasibility", "source_json_path", "generation_id", "decision_outcome", "disposition_rationale"],
                  "properties": {
                    "id": {"type": "string", "minLength": 1},
                    "idea_id": {"type": "string", "minLength": 1},
                    "title": {"type": "string", "minLength": 1},
                    "summary": {"type": "string", "minLength": 1},
                    "source_json_path": {"type": "string", "pattern": "^\\$\\.sections\\.proposals\\[[0-9]+\\]$"},
                    "generation_id": {"type": "string", "minLength": 1},
                    "decision_outcome": {"enum": ["considered", "selected", "not_selected", "shortlisted", "deferred", "closed", "reopened"]},
                    "disposition_rationale": {"type": "string", "minLength": 1},
                    "transition_required": {"type": "boolean"},
                    "closure_reason": {"enum": ["rejection", "supersession", "duplication", "invalidation", "user_closure", "other"]}
                  },
                  "allOf": [
                    {
                      "if": {"properties": {"decision_outcome": {"const": "closed"}}, "required": ["decision_outcome"]},
                      "then": {"required": ["closure_reason"]}
                    }
                  ],
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ],
  "$defs": {
    "researchIdeaEffects": {
      "type": "object",
      "required": ["atomic", "ideas"],
      "properties": {
        "atomic": {"const": true},
        "artifact_family": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "operation_id": {"type": "string", "minLength": 1},
        "ideas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["idea_id", "title", "summary", "source_json_path", "exploration_state", "decision_state", "evidence_state", "archive_state", "visibility"],
            "properties": {
              "idea_id": {"type": "string", "minLength": 1},
              "title": {"type": "string", "minLength": 1},
              "summary": {"type": "string", "minLength": 1},
              "source_json_path": {"type": "string", "pattern": "^\\$\\."},
              "exploration_state": {"enum": ["unknown", "unexplored", "exploring", "explored"]},
              "decision_state": {"enum": ["unknown", "open", "shortlisted", "selected", "deferred", "closed"]},
              "evidence_state": {"enum": ["unknown", "unassessed", "inconclusive", "supported", "mixed", "refuted"]},
              "archive_state": {"enum": ["active", "archived"]},
              "visibility": {"enum": ["primary", "supporting", "hidden"]},
              "aliases": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
              "generation_id": {"type": "string", "minLength": 1},
              "decision_outcome": {"enum": ["considered", "selected", "not_selected", "shortlisted", "deferred", "closed", "reopened"]},
              "disposition_rationale": {"type": "string", "minLength": 1},
              "closure_reason": {"enum": ["rejection", "supersession", "duplication", "invalidation", "user_closure", "legacy_rejection", "legacy_supersession", "other"]}
            },
            "additionalProperties": true
          }
        },
        "generation_groups": {"type": "array", "items": {"type": "object", "required": ["generation_id", "member_idea_ids"], "properties": {"generation_id": {"type": "string", "minLength": 1}, "member_idea_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true}, "parent_idea_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}}, "additionalProperties": true}},
        "lineage_edges": {"type": "array", "items": {"type": "object", "required": ["parent_idea_id", "child_idea_id", "lineage_kind"], "properties": {"parent_idea_id": {"type": "string", "minLength": 1}, "child_idea_id": {"type": "string", "minLength": 1}, "lineage_kind": {"enum": ["derived_from", "selected_from", "merged_from", "follow_up_to", "alternative_to", "subsumes"]}}, "additionalProperties": true}},
        "decision_options": {"type": "array", "items": {"type": "object", "required": ["idea_id", "outcome", "rationale"], "properties": {"decision_record_id": {"type": "string", "minLength": 1}, "idea_id": {"type": "string", "minLength": 1}, "outcome": {"enum": ["considered", "selected", "not_selected", "shortlisted", "deferred", "closed", "reopened"]}, "ordinal": {"type": "integer", "minimum": 0}, "generation_id": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}, "consequence": {"type": "string"}, "actor_ref": {"type": "string", "minLength": 1}, "supporting_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}}, "additionalProperties": true}},
        "transitions": {"type": "array", "items": {"type": "object", "required": ["idea_id", "facet", "previous_value", "next_value", "actor_ref", "rationale"], "properties": {"idea_id": {"type": "string", "minLength": 1}, "facet": {"enum": ["exploration_state", "decision_state", "evidence_state", "archive_state", "visibility"]}, "previous_value": {"type": "string", "minLength": 1}, "next_value": {"type": "string", "minLength": 1}, "actor_ref": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}, "reason_code": {"enum": ["rejection", "supersession", "duplication", "invalidation", "user_closure", "legacy_rejection", "legacy_supersession", "other"]}, "decision_record_id": {"type": "string", "minLength": 1}, "gate_id": {"type": "string", "minLength": 1}, "evidence_item_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "artifact_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "finding_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "research_task_id": {"type": "string", "minLength": 1}, "run_id": {"type": "string", "minLength": 1}, "provenance_record_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}}, "allOf": [{"if": {"properties": {"facet": {"const": "decision_state"}, "next_value": {"const": "closed"}}, "required": ["facet", "next_value"]}, "then": {"required": ["reason_code"]}}], "additionalProperties": true}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
