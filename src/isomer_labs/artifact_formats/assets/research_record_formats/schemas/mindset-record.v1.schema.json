{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isomer:research/record-format/schema/mindset-record/v1",
  "title": "Family-neutral materialized mindset record",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "summary", "artifact_family", "semantic_id", "artifact_type", "sections"],
  "properties": {
    "title": {"type": "string", "minLength": 1, "maxLength": 300},
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "artifact_family": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "semantic_id": {"type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+)*:[A-Z0-9]+(?:-[A-Z0-9]+)*$"},
    "artifact_type": {"const": "mindset-record"},
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_snapshot", "survey_context", "supplemental_questions", "source_update", "unresolved_questions", "terminal_status"],
      "properties": {
        "source_snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["semantic_label", "relative_path", "mindset_key", "digest", "questions", "additional_question_collector"],
          "properties": {
            "semantic_label": {"const": "topic.intent.kaoju_mindsets"},
            "relative_path": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*\\.json$", "maxLength": 85},
            "mindset_key": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$", "maxLength": 80},
            "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
            "derivation": {
              "type": "object",
              "additionalProperties": false,
              "required": ["overview_semantic_label", "overview_digest", "seed_version", "seed_digest"],
              "properties": {
                "overview_semantic_label": {"const": "topic.intent.overview"},
                "overview_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                "seed_version": {"type": "string", "minLength": 1, "maxLength": 40},
                "seed_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
              }
            },
            "questions": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"$ref": "#/$defs/materializedQuestion"}},
            "additional_question_collector": {
              "allOf": [
                {"$ref": "#/$defs/materializedQuestion"},
                {
                  "type": "object",
                  "required": ["checked"],
                  "properties": {"question_id": {"const": "additional-questions"}, "checked": {"type": "boolean"}}
                }
              ]
            }
          }
        },
        "survey_context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["topic_id", "run_ref", "survey_contract_ref", "context_refs"],
          "properties": {
            "topic_id": {"type": "string", "minLength": 1, "maxLength": 200},
            "run_ref": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+~-]{0,299}$"},
            "survey_contract_ref": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+~-]{0,299}$"},
            "context_refs": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+~-]{0,299}$"}}
          }
        },
        "supplemental_questions": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/supplementalQuestion"}},
        "source_update": {
          "type": "object",
          "additionalProperties": false,
          "required": ["disposition"],
          "properties": {
            "disposition": {"enum": ["record_only", "source_update_requested", "source_updated"]},
            "new_relative_path": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*\\.json$", "maxLength": 85},
            "new_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          },
          "allOf": [
            {
              "if": {"properties": {"disposition": {"const": "source_updated"}}, "required": ["disposition"]},
              "then": {"required": ["new_relative_path", "new_digest"]},
              "else": {"not": {"anyOf": [{"required": ["new_relative_path"]}, {"required": ["new_digest"]}]}}
            }
          ]
        },
        "unresolved_questions": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 200}},
        "terminal_status": {"enum": ["active", "complete", "paused", "blocked"]}
      }
    }
  },
  "$defs": {
    "materializedQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_id", "prompt", "additional_notes", "answer_expectation", "required_posture", "evidence_expectation", "answer_state", "answer", "rationale", "evidence_refs"],
      "properties": {
        "question_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80},
        "prompt": {"type": "string", "minLength": 1, "maxLength": 2000},
        "additional_notes": {"type": "string", "maxLength": 4000},
        "answer_expectation": {"type": "string", "minLength": 1, "maxLength": 2000},
        "required_posture": {"enum": ["answer-or-unresolved", "answer-or-not-applicable", "collect-explicit-only"]},
        "evidence_expectation": {"type": "string", "minLength": 1, "maxLength": 2000},
        "answer_state": {"enum": ["unanswered", "answered", "unresolved", "not_applicable"]},
        "answer": {"type": ["string", "null"], "maxLength": 12000},
        "rationale": {"type": ["string", "null"], "maxLength": 4000},
        "evidence_refs": {"type": "array", "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+~-]{0,299}$"}},
        "checked": {"type": "boolean"},
        "origin": {"enum": ["user", "agent"]},
        "association_basis": {"type": "string", "minLength": 1, "maxLength": 1000},
        "introduction_stage": {"type": "string", "minLength": 1, "maxLength": 120},
        "disposition": {"enum": ["record_only", "source_update_requested", "source_updated"]}
      }
    },
    "supplementalQuestion": {
      "allOf": [
        {"$ref": "#/$defs/materializedQuestion"},
        {
          "type": "object",
          "required": ["origin", "association_basis", "introduction_stage", "disposition"],
          "properties": {
            "origin": {"enum": ["user", "agent"]},
            "association_basis": {"type": "string", "minLength": 1, "maxLength": 1000},
            "introduction_stage": {"type": "string", "minLength": 1, "maxLength": 120},
            "disposition": {"enum": ["record_only", "source_update_requested", "source_updated"]}
          }
        }
      ]
    }
  }
}
