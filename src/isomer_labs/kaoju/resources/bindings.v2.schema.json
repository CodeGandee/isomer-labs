{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isomer:kaoju/binding-registry/v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "family",
    "bindings"
  ],
  "properties": {
    "schema_version": {
      "const": "isomer-kaoju-binding-registry.v2"
    },
    "family": {
      "const": "kaoju"
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/binding"
      }
    }
  },
  "$defs": {
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_id",
        "artifact_type",
        "record_kind",
        "profile_ref",
        "semantic_label",
        "content_mode",
        "producer",
        "consumers",
        "relationships",
        "revision_mode",
        "scope_key_policy",
        "latest_selection_policy",
        "validation",
        "acceptance",
        "status"
      ],
      "properties": {
        "semantic_id": {
          "type": "string",
          "pattern": "^KAOJU:[A-Z0-9]+(?:-[A-Z0-9]+)*$"
        },
        "artifact_type": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "record_kind": {
          "enum": [
            "artifact",
            "decision_record",
            "evidence_item",
            "gate",
            "run",
            "view_manifest"
          ]
        },
        "profile_ref": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^isomer:research/record-format/profile/kaoju/.+/v(?:1|2)$"
        },
        "semantic_label": {
          "enum": [
            "topic.records.artifacts",
            "topic.records.logs",
            "topic.records.runs",
            "topic.records.views"
          ]
        },
        "content_mode": {
          "enum": [
            "structured_file",
            "ordinary_file",
            "directory_manifest",
            "external_path",
            "canonical_repository"
          ]
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "consumers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "relationships": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        },
        "revision_mode": {
          "enum": [
            "current_state",
            "mutable_state",
            "append_only",
            "immutable"
          ]
        },
        "scope_key_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "dimension"
          ],
          "properties": {
            "mode": {
              "enum": [
                "none",
                "optional",
                "required"
              ]
            },
            "dimension": {
              "enum": [
                "topic",
                "survey",
                "direction",
                "source",
                "paper_line",
                "template_name",
                "export_target",
                "environment",
                "trial",
                "run",
                "request"
              ]
            }
          }
        },
        "latest_selection_policy": {
          "enum": [
            "topic_current",
            "scoped_current",
            "mutable_named",
            "append_only",
            "immutable_ref"
          ]
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "contract"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "contract": {
              "enum": [
                "structured-record",
                "file-integrity",
                "directory-manifest",
                "external-locator",
                "repository-identity"
              ]
            }
          }
        },
        "acceptance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "statuses",
            "gate"
          ],
          "properties": {
            "statuses": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "active",
                  "ready",
                  "complete",
                  "supported",
                  "blocked",
                  "resolved",
                  "failed",
                  "stale",
                  "archived"
                ]
              }
            },
            "gate": {
              "enum": [
                "none",
                "human",
                "publication",
                "network_exposure"
              ]
            }
          }
        },
        "status": {
          "enum": [
            "active",
            "compatibility",
            "deprecated"
          ]
        },
        "migration": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "canonical_successor": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^KAOJU:[A-Z0-9]+(?:-[A-Z0-9]+)*$"
            },
            "automatic_promotion": {
              "type": "boolean"
            },
            "permitted_relationships": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
