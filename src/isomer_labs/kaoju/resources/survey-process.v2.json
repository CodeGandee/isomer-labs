  "template_roles": {
    "content": {
      "semantic_id": "KAOJU:PAPER-TEMPLATE-MYST",
      "default_name": "main",
      "exchange_subdirectory": "content",
      "purpose": "Canonical MyST authoring structure and content guidance."
    },
    "latex": {
      "semantic_id": "KAOJU:PAPER-TEMPLATE-LATEX",
      "default_name": "main",
      "exchange_subdirectory": "latex",
      "purpose": "Multi-file LaTeX presentation stock composed into paper-line TeX snapshots.",
      "composition_modes": [
        "preamble",
        "marker",
        "include"
      ]
    }
  },
  "supersession": {
    "source_change": "add-kaoju-paper-writing",
    "governing_decision": "context/features/2026-07-14-kaoju-survey-process-usecases/adrs/0006-myst-as-canonical-paper-format.md",
    "replaced_requirements": [
      "LaTeX source is canonical paper state",
      "KAOJU:WRITING-TEMPLATE is the canonical template",
      "ext research templates creates new canonical templates",
      "Markdown publication input is rejected instead of represented as a derived view",
      "create-paper-template writes a canonical LaTeX tree under intent/derived/writing-template"
    ],
    "superseded_incomplete_tests": [
      "add-kaoju-paper-writing tasks 5.1 through 5.8 when they assert a LaTeX-first canonical source or reject the MyST-derived publication path"
    ],
    "retained_behavior": [
      "accepted audit and synthesis prerequisites",
      "citation and exact evidence traceability",
      "multidimensional survey-quality validation",
      "immutable build attempts and exact build provenance",
      "compiler-owned TeX numbering",
      "textual and visual PDF inspection",
      "publication Gate and no implicit external publication"
    ],
    "legacy_posture": "Historical LaTeX-first records remain readable. They are never promoted to canonical MyST without an actor-authorized intake with explicit provenance."
  },
  "implementation_decisions": {
    "myst_parser": {
      "distribution": "myst-parser",
      "constraint": ">=5.1.0,<6",
      "locked_selection": "5.1.0",
      "python_requirement": ">=3.11",
      "purpose": "Structural MyST parsing, validation diagnostics, and TeX initialization."
    },
    "paper_templates": {
      "content_identity": "KAOJU:PAPER-TEMPLATE-MYST",
      "latex_identity": "KAOJU:PAPER-TEMPLATE-LATEX",
      "independent_defaults": true,
      "derived_snapshot_identity": "KAOJU:PAPER-TEMPLATE-TEX",
      "paper_local_repair_identity": "KAOJU:PAPER-DRAFT-TEX",
      "drift_policy": "report working-copy, stocked-template, and paper-local repair drift without automatic propagation"
    },
    "wiki_viewer": {
      "decision": "independent-compatible-implementation",
      "candidate": "imsight-llm-wiki viewer",
      "review_result": "The available migration copy names its source path but contains no LICENSE, COPYING, NOTICE, license field, repository remote, or commit identity sufficient for redistribution.",
      "prohibition": "Do not copy, import, load, or invoke candidate viewer or external imsight-llm-wiki skill code.",
      "implementation": "Package an independently written static viewer that reads the documented Kaoju wiki JSON manifest."
    }
  },
  "binding_queries": {
    "list": "isomer-cli --print-json ext kaoju bindings list",
    "describe": "isomer-cli --print-json ext kaoju bindings describe KAOJU:WHAT"
