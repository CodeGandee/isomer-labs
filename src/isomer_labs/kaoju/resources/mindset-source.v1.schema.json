{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isomer:kaoju/mindset-source/v1",
  "title": "Kaoju Mindset Source",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mindset_key", "purpose", "applicability", "questions", "additional_question_collector"],
  "properties": {
    "schema_version": {"const": "isomer-kaoju-mindset-source.v1"},
    "mindset_key": {"type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$", "maxLength": 80},
    "purpose": {"type": "string", "minLength": 1, "maxLength": 1000},
    "applicability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actions", "source_kinds", "depths"],
      "properties": {
        "actions": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80}},
        "source_kinds": {"type": "array", "minItems": 1, "maxItems": 12, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80}},
        "depths": {"type": "array", "minItems": 1, "maxItems": 12, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80}}
      }
    },
    "derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overview_semantic_label", "overview_digest", "seed_version", "seed_digest"],
      "properties": {
        "overview_semantic_label": {"const": "topic.intent.overview"},
        "overview_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "seed_version": {"type": "string", "minLength": 1, "maxLength": 40},
        "seed_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "questions": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"$ref": "#/$defs/question"}},
    "additional_question_collector": {
      "allOf": [
        {"$ref": "#/$defs/question"},
        {
          "type": "object",
          "required": ["repeatable"],
          "properties": {"question_id": {"const": "additional-questions"}, "repeatable": {"const": true}}
        }
      ]
    }
  },
  "$defs": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_id", "prompt", "additional_notes", "answer_expectation", "required_posture", "evidence_expectation"],
      "properties": {
        "question_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80},
        "prompt": {"type": "string", "minLength": 1, "maxLength": 2000},
        "additional_notes": {"type": "string", "maxLength": 4000},
        "answer_expectation": {"type": "string", "minLength": 1, "maxLength": 2000},
        "required_posture": {"enum": ["answer-or-unresolved", "answer-or-not-applicable", "collect-explicit-only"]},
        "evidence_expectation": {"type": "string", "minLength": 1, "maxLength": 2000},
        "repeatable": {"type": "boolean"}
      }
    }
  }
}
