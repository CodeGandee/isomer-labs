{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isomer:deepsci/record-format/schema/shared/structured-record/v2",
  "title": "DeepSci structured research record payload",
  "type": "object",
  "required": [
    "title",
    "summary"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "status": {
      "type": "string"
    },
    "sections": {
      "type": "object"
    },
    "items": {
      "type": "array"
    },
    "metadata": {
      "type": "object"
    },
    "content": {
      "type": "object"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
