{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "isomer:deepsci/record-format/schema/control/topic-reset-checkpoint/v1",
  "title": "Topic reset checkpoint payload",
  "type": "object",
  "required": [
    "title",
    "summary",
    "status",
    "research_topic_id",
    "topic_workspace_id",
    "checkpoint_id",
    "workspace_runtime_schema_version",
    "semantic_path_inventory",
    "preserved_record_ids",
    "preserved_structured_payload_ids",
    "runtime_high_watermarks",
    "blockers",
    "no_git_operations"
  ],
  "properties": {
    "title": {"type": "string"},
    "summary": {"type": "string"},
    "status": {"type": "string", "enum": ["ready", "blocked", "stale"]},
    "research_topic_id": {"type": "string"},
    "topic_workspace_id": {"type": "string"},
    "checkpoint_id": {"type": "string"},
    "actor_ref": {"type": ["string", "null"]},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "workspace_runtime_schema_version": {"type": "string"},
    "source_readiness_evidence": {"type": ["object", "null"]},
    "topic_workspace_summary_ref": {"type": ["string", "null"]},
    "summary_paths": {"type": "array", "items": {"type": "string"}},
    "semantic_path_inventory": {"type": "array", "items": {"type": "object"}},
    "preserved_record_ids": {"type": "array", "items": {"type": "string"}},
    "preserved_structured_payload_ids": {"type": "array", "items": {"type": "string"}},
    "preserved_generated_view_paths": {"type": "array", "items": {"type": "string"}},
    "preserved_artifact_format_registration_ids": {"type": "array", "items": {"type": "string"}},
    "preserved_readiness_record_ids": {"type": "array", "items": {"type": "string"}},
    "preserved_semantic_labels": {"type": "array", "items": {"type": "string"}},
    "preserved_support_paths": {"type": "array", "items": {"type": "string"}},
    "runtime_high_watermarks": {"type": "object"},
    "blockers": {"type": "array", "items": {"type": "object"}},
    "extensions": {"type": "array", "items": {"type": "object"}},
    "provenance_refs": {"type": "array", "items": {"type": "string"}},
    "no_git_operations": {"const": true}
  },
  "additionalProperties": false
}
