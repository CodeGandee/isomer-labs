#!/usr/bin/env python3
"""DeepResearch harness entrypoint. Adds src/ to sys.path and dispatches the click CLI."""
import sys
from pathlib import Path

_SRC = Path(__file__).resolve().parents[1] / "src"
if str(_SRC) not in sys.path:
    sys.path.insert(0, str(_SRC))

try:
    from cli import main
except ImportError as exc:  # missing generated harness dependency
    pkg = str(exc).split("'")[1] if "'" in str(exc) else str(exc)
    sys.stderr.write(
        f"Missing generated harness dependency: {pkg}\n"
        "Install it into the Python environment running this harness, or use the Houmao "
        "uv-installed environment (uv tool install --force houmao).\n"
    )
    raise SystemExit(1)

if __name__ == "__main__":
    main()
