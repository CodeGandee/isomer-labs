{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/harness/command-envelope",
  "title": "harness command envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "command", "data"],
  "properties": {
    "ok": { "type": "boolean" },
    "command": { "type": "string" },
    "quest_id": { "type": ["string", "null"] },
    "plan_revision": { "type": ["integer", "string", "null"] },
    "data": { "type": "object" },
    "diagnostics": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
