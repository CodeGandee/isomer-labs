{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/comms/receipt",
  "title": "receipt payload",
  "description": "Worker -> requester interim acknowledgement that a task-request was accepted. Echoes handoff_id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "accepted"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_version", "kind", "loop_slug", "loop_id", "handoff_id", "continuation_lane", "payload_id", "from_role", "to_role", "reply_to_payload_id"],
      "properties": {
        "schema_id": { "const": "deepresearch.email.receipt" },
        "schema_version": { "type": "string" },
        "kind": { "const": "receipt" },
        "loop_slug": { "const": "deepresearch" },
        "loop_id": { "type": "string" },
        "handoff_id": { "type": "string", "description": "MUST equal the task-request handoff_id" },
        "continuation_lane": { "type": "string", "default": "main" },
        "payload_id": { "type": "string" },
        "plan_revision": { "type": ["integer", "string"] },
        "round_index": { "type": ["integer", "string"] },
        "from_role": { "type": "string" },
        "to_role": { "const": "orchestrator" },
        "reply_to_payload_id": { "type": "string", "description": "the task-request payload_id" }
      }
    },
    "accepted": { "type": "boolean", "description": "true = work started; false = cannot take it (with reason)" },
    "reason": { "type": "string", "description": "required when accepted=false" },
    "eta": { "type": "string", "description": "optional ISO-8601 expected result time" }
  }
}
