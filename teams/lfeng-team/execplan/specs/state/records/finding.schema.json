{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/records/finding",
  "title": "finding add",
  "description": "Persist a durable finding/reflexion lesson. scope='quest' (default) requires quest_id (invariant quest_finding_has_quest); 'global' may omit it.",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_type", "record_id", "at", "scope", "kind", "summary"],
  "properties": {
    "record_type": { "const": "finding.add" },
    "record_id": { "type": "string" },
    "at": { "type": "string" },
    "quest_id": { "type": ["string", "null"] },
    "scope": { "enum": ["quest", "global"], "default": "quest" },
    "kind": { "enum": ["idea", "decision", "knowledge", "lesson", "reference"] },
    "summary": { "type": "string" },
    "artifact_ref": { "type": "string" },
    "grounded_by": { "type": "string", "description": "ref to the measurement/result the lesson is grounded in" }
  },
  "allOf": [
    {
      "if": { "properties": { "scope": { "const": "quest" } } },
      "then": { "required": ["quest_id"], "properties": { "quest_id": { "type": "string" } } }
    }
  ]
}
