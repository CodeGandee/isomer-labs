{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/records/intake",
  "title": "intake_asset record",
  "description": "Record a pre-existing asset audited at quest entry (intake-audit stage). record_id = asset_id. adopt_as may only be set when trust='trusted' (invariant intake_adopt_trusted).",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_type", "record_id", "at", "quest_id", "kind", "source_ref", "trust"],
  "properties": {
    "record_type": { "const": "intake_asset.record" },
    "record_id": { "type": "string" },
    "at": { "type": "string" },
    "quest_id": { "type": "string" },
    "kind": { "enum": ["baseline", "result", "draft", "dataset", "code", "paper", "other"] },
    "source_ref": { "type": "string" },
    "trust": { "enum": ["trusted", "suspect", "untrusted", "rejected"] },
    "adopt_as": { "type": "string", "description": "id/token of the state row this asset was adopted into; requires trust='trusted'" },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "required": ["adopt_as"], "properties": { "adopt_as": { "type": "string", "minLength": 1 } } },
      "then": { "properties": { "trust": { "const": "trusted" } } }
    }
  ]
}
