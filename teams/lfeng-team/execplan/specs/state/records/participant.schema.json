{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/records/participant",
  "title": "participant register",
  "description": "Bind a role instance to a quest. record_id = '<quest_id>:<instance_id>'.",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_type", "record_id", "at", "quest_id", "instance_id", "role"],
  "properties": {
    "record_type": { "const": "participant.register" },
    "record_id": { "type": "string" },
    "at": { "type": "string" },
    "quest_id": { "type": "string" },
    "instance_id": { "type": "string" },
    "role": { "enum": ["orchestrator", "scout-ideator", "experimenter", "analyst", "writer", "reviewer"] },
    "tool": { "enum": ["claude", "codex", "gemini"] },
    "last_seen": { "type": "string" }
  }
}
