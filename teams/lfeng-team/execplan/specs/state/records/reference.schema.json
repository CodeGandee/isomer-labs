{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/records/reference",
  "title": "reference record",
  "description": "Record a fetched external source (literature harness). arxiv/web sources require a cached artifact_ref (invariant fetched_reference_cached). record_id = reference_id.",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_type", "record_id", "at", "source", "uri", "fetched_at"],
  "properties": {
    "record_type": { "const": "reference.record" },
    "record_id": { "type": "string" },
    "at": { "type": "string" },
    "quest_id": { "type": ["string", "null"], "description": "null = cross-quest cached source" },
    "source": { "enum": ["arxiv", "web", "doi", "manual"] },
    "cite_key": { "type": "string" },
    "title": { "type": "string" },
    "uri": { "type": "string" },
    "artifact_ref": { "type": "string" },
    "fetched_at": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "source": { "enum": ["arxiv", "web"] } } },
      "then": { "required": ["artifact_ref"], "properties": { "artifact_ref": { "type": "string", "minLength": 1 } } }
    }
  ]
}
