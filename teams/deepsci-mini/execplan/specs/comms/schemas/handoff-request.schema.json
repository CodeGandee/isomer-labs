{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepsci-mini.email.handoff-request",
  "title": "deepsci-mini handoff request mail",
  "type": "object",
  "required": ["schema_id", "schema_version", "kind", "run_id", "plan_revision", "handoff_id", "sender_role", "receiver_role", "research_topic_id", "research_inquiry_id", "research_task_id", "workflow_stage", "summary", "expected_outputs"],
  "properties": {
    "schema_id": {"const": "deepsci-mini.email.handoff-request"},
    "schema_version": {"const": "1"},
    "kind": {"const": "request"},
    "run_id": {"type": "string", "minLength": 1},
    "plan_revision": {"type": "string", "minLength": 1},
    "handoff_id": {"type": "string", "minLength": 1},
    "sender_role": {"const": "deepsci-mini-lead"},
    "receiver_role": {"enum": ["deepsci-mini-scout", "deepsci-mini-synth-reviewer"]},
    "research_topic_id": {"type": "string", "minLength": 1},
    "research_inquiry_id": {"type": "string", "minLength": 1},
    "research_task_id": {"type": "string", "minLength": 1},
    "workflow_stage": {"enum": ["scout", "literature-note", "synthesis-review"]},
    "summary": {"type": "string", "minLength": 1},
    "expected_outputs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "input_refs": {"type": "array", "items": {"type": "string"}},
    "gate_policy_refs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
