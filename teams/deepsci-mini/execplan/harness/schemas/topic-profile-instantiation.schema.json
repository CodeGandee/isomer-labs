{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepsci-mini.topic-profile-instantiation",
  "title": "deepsci-mini topic profile instantiation parameters",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "domain_agent_team_template_ref",
    "research_topic_id",
    "research_topic_config_ref",
    "topic_workspace_ref",
    "workspace_runtime_ref",
    "topic_agent_team_profile_bundle_ref",
    "coordination_policy_ref",
    "gate_policy_ref",
    "role_bindings"
  ],
  "properties": {
    "domain_agent_team_template_ref": {
      "type": "string",
      "minLength": 1
    },
    "research_topic_id": {
      "type": "string",
      "minLength": 1
    },
    "research_topic_config_ref": {
      "type": "string",
      "minLength": 1
    },
    "topic_workspace_ref": {
      "type": "string",
      "minLength": 1
    },
    "workspace_runtime_ref": {
      "type": "string",
      "minLength": 1
    },
    "topic_agent_team_profile_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "topic_agent_team_profile_id": {
      "type": "string",
      "description": "Derived compatibility metadata for the topic-level specialization, not a caller-selected profile id."
    },
    "agent_team_instance_id": {
      "type": "string"
    },
    "coordination_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "gate_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "control_mode": {
      "type": "string",
      "enum": [
        "manual",
        "automatic"
      ]
    },
    "role_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role_id",
          "agent_profile_ref",
          "capability_binding_ref",
          "skill_binding_projection_ref"
        ],
        "properties": {
          "role_id": {
            "type": "string"
          },
          "agent_profile_ref": {
            "type": "string",
            "minLength": 1
          },
          "capability_binding_ref": {
            "type": "string",
            "minLength": 1
          },
          "skill_binding_projection_ref": {
            "type": "string",
            "minLength": 1
          },
          "agent_workspace_ref": {
            "type": "string"
          }
        }
      }
    }
  }
}
