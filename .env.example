# Optional Claude-compatible Kimi settings for tests that need an external coding LLM.
#
# Usage:
# 1. Copy this file to .env.
# 2. Fill CLAUDE_KIMI_ANTHROPIC_API_KEY with your local Kimi key. The launcher
#    exits with an error when this value is unset, empty, blank, or still the
#    placeholder below.
# 3. Keep .env uncommitted. It is ignored by git.
# 4. Use ./scripts/claude-kimi.sh to start Claude against the Kimi endpoint.
#    The script reads these prefixed variables and maps them to ANTHROPIC_BASE_URL,
#    ANTHROPIC_API_KEY, and CLAUDE_CODE_AUTO_COMPACT_WINDOW only for the child
#    Claude/Kimi process. Do not export unprefixed values globally, because that
#    can interfere with normal Claude apps.
#
# Example one-off shell mapping:
#   set -a; source .env; set +a
#   ./scripts/claude-kimi.sh --version
export CLAUDE_KIMI_ANTHROPIC_BASE_URL='https://api.kimi.com/coding/'
export CLAUDE_KIMI_ANTHROPIC_API_KEY='<your-kimi-api-key>'
export CLAUDE_KIMI_AUTO_COMPACT_WINDOW='262144'
# Optional override; defaults to kimi-for-coding.
# export CLAUDE_KIMI_MODEL='kimi-for-coding'
