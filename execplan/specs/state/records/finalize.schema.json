{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/records/finalize",
  "title": "finalize_outcome record",
  "description": "Record a finalize outcome. record_id = outcome_id. 'park' requires reopen_conditions; 'publish_and_continue' requires next_incumbent_ref (invariants park_has_reopen / publish_has_incumbent). The Orchestrator pairs this with the matching quest.update run_state.",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_type", "record_id", "at", "quest_id", "outcome"],
  "properties": {
    "record_type": { "const": "finalize.record" },
    "record_id": { "type": "string" },
    "at": { "type": "string" },
    "quest_id": { "type": "string" },
    "outcome": { "enum": ["complete", "stop", "park", "publish_and_continue"] },
    "published_ref": { "type": "string" },
    "next_incumbent_ref": { "type": "string" },
    "reopen_conditions": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "park" } } },
      "then": { "required": ["reopen_conditions"], "properties": { "reopen_conditions": { "type": "string", "minLength": 1 } } }
    },
    {
      "if": { "properties": { "outcome": { "const": "publish_and_continue" } } },
      "then": { "required": ["next_incumbent_ref"], "properties": { "next_incumbent_ref": { "type": "string", "minLength": 1 } } }
    }
  ]
}
