{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/records/result",
  "title": "result + measurement records",
  "description": "Record a validated experiment outcome, or a schema-light measurement. Only validity='valid' results may back a supported claim or update best_result_ref.",
  "oneOf": [
    {
      "title": "result.record",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "record_id", "at", "quest_id", "experiment_id", "artifact_ref"],
      "properties": {
        "record_type": { "const": "result.record" },
        "record_id": { "type": "string" },
        "at": { "type": "string" },
        "quest_id": { "type": "string" },
        "experiment_id": { "type": "string" },
        "round_index": { "type": "integer", "minimum": 0 },
        "validity": { "enum": ["unchecked", "valid", "invalid", "incomparable"], "default": "unchecked" },
        "artifact_ref": { "type": "string" }
      }
    },
    {
      "title": "measurement.record",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "record_id", "at", "result_id", "metric_name"],
      "anyOf": [ { "required": ["value_num"] }, { "required": ["value_text"] } ],
      "properties": {
        "record_type": { "const": "measurement.record" },
        "record_id": { "type": "string" },
        "at": { "type": "string" },
        "result_id": { "type": "string" },
        "metric_name": { "type": "string" },
        "value_num": { "type": "number" },
        "value_text": { "type": "string" },
        "unit": { "type": "string" },
        "is_primary": { "type": "boolean", "description": "the single BO objective per result (invariant single_primary_measurement)" },
        "artifact_ref": { "type": "string" }
      }
    }
  ]
}
