{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/records/claim",
  "title": "claim + evidence records",
  "description": "Upsert a claim, link evidence, or resolve a contradiction. A 'supported' claim needs supports-evidence from valid results/analyses and no contradicts link with resolved=0.",
  "oneOf": [
    {
      "title": "claim.upsert",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "record_id", "at", "quest_id", "statement", "status"],
      "properties": {
        "record_type": { "const": "claim.upsert" },
        "record_id": { "type": "string" },
        "at": { "type": "string" },
        "quest_id": { "type": "string" },
        "statement": { "type": "string" },
        "status": { "enum": ["open", "supported", "refuted", "withdrawn"] }
      }
    },
    {
      "title": "claim_evidence.link",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "record_id", "at", "claim_id", "source_kind", "source_ref", "relation"],
      "properties": {
        "record_type": { "const": "claim_evidence.link" },
        "record_id": { "type": "string", "description": "= '<claim_id>:<source_kind>:<source_ref>'" },
        "at": { "type": "string" },
        "claim_id": { "type": "string" },
        "source_kind": { "enum": ["result", "analysis", "measurement", "reference", "external"] },
        "source_ref": { "type": "string" },
        "relation": { "enum": ["supports", "contradicts", "contextualizes"] }
      }
    },
    {
      "title": "claim_evidence.resolve",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "record_id", "at", "claim_id", "source_kind", "source_ref", "resolution_ref"],
      "properties": {
        "record_type": { "const": "claim_evidence.resolve" },
        "record_id": { "type": "string" },
        "at": { "type": "string" },
        "claim_id": { "type": "string" },
        "source_kind": { "enum": ["result", "analysis", "measurement", "reference", "external"] },
        "source_ref": { "type": "string" },
        "resolution_ref": { "type": "string", "description": "artifact/decision rebutting the contradiction; sets resolved=1" }
      }
    }
  ]
}
