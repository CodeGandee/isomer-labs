{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deepresearch/records/wakeup",
  "title": "self-wakeup records",
  "description": "Arm/attach/resolve the durable continuation spine. record_id = wakeup_id. One open wakeup per (quest, continuation_lane); one active lane per quest initially.",
  "oneOf": [
    {
      "title": "wakeup.arm",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "record_id", "at", "quest_id", "handoff_id", "reason"],
      "properties": {
        "record_type": { "const": "wakeup.arm" },
        "record_id": { "type": "string" },
        "at": { "type": "string" },
        "quest_id": { "type": "string" },
        "continuation_lane": { "type": "string", "default": "main" },
        "handoff_id": { "type": "string" },
        "next_stage": { "type": "string" },
        "reason": { "type": "string" },
        "next_action": { "type": "string" },
        "deliver_after": { "type": "string" }
      }
    },
    {
      "title": "wakeup.attach",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "record_id", "at", "message_ref"],
      "properties": {
        "record_type": { "const": "wakeup.attach" },
        "record_id": { "type": "string" },
        "at": { "type": "string" },
        "message_ref": { "type": "string" }
      }
    },
    {
      "title": "wakeup.resolve",
      "type": "object",
      "additionalProperties": false,
      "required": ["record_type", "record_id", "at", "status"],
      "properties": {
        "record_type": { "const": "wakeup.resolve" },
        "record_id": { "type": "string" },
        "at": { "type": "string" },
        "status": { "enum": ["delivered", "consumed", "superseded", "failed"] }
      }
    }
  ]
}
